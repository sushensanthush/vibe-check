      "import": "./dist/vibe-check.es.js",
      "require": "./dist/vibe-check.umd.js"
    }
  },
  "scripts": {
    "build": "vite build"
  },
  "keywords": [
    "network",
    "latency",
    "connectivity",
    "vibe-check",
    "offline-first",
    "ux",
    "performance"
  ],
  "author": "sushensanthush",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0"
  },
  "dependencies": {
    "@sushensanthush/vibe-check": "^1.0.0"
  }
}

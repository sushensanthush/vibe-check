{
  "name": "@sushensanthush/vibe-check",
  "version": "1.0.0",
  "description": "A lightweight, intelligent network monitor that tracks latency and connection quality (excellent, stuttering, or offline).",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/vibe-check.umd.js",
  "module": "./dist/vibe-check.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
